# Environment
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=listopled
DB_USER=listopled_user
DB_PASSWORD=change_me_database_password

# JWT
JWT_SECRET=change_me_min_32_chars_placeholder
JWT_ISSUER=listopled-api
JWT_AUDIENCE=listopled-client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14

# Admin seed
ADMIN_EMAIL=admin@listopled.local
ADMIN_PASSWORD=change_me_dev_admin_password
ADMIN_DISPLAY_NAME=Анна

# Redis / Valkey
CACHE_PROVIDER=Valkey
REDIS_CONNECTION=redis:6379

# MinIO / S3-compatible storage
STORAGE_PROVIDER=Local
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_BUCKET=listopled-media
MINIO_USE_SSL=false

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Frontend / Nuxt
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_HOST=0.0.0.0
NUXT_PORT=3000
INTERNAL_API_BASE_URL=http://api:8080/api/v1

# CORS
CORS_ORIGIN=http://localhost:3000

# Umami
ANALYTICS_ENABLED=true
UMAMI_ENABLED=false
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=
